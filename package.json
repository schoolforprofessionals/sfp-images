{
  "author": "School for Professionals",
  "bin": {
    "sfp-image": "dist/cli.mjs"
  },
  "bugs": {
    "url": "https://github.com/schoolforprofessionals/sfp-images/issues"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.2.3",
    "@resvg/resvg-js": "^2.6.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "commander": "^14.0.3",
    "hono": "^4.12.9",
    "opentype.js": "^1.3.4",
    "react": "^19.2.4",
    "satori": "^0.26.0",
    "zod": "^4.3.6"
  },
  "description": "CLI and library for generating branded images for School for Professionals sites from structured input.",
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@changesets/cli": "^2.29.8",
    "@intellectronica/ruler": "^0.3.34",
    "@types/bun": "1.3.11",
    "@types/opentype.js": "^1.3.9",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "pixelmatch": "^7.1.0",
    "pkg-pr-new": "^0.0.62",
    "pngjs": "^7.0.0",
    "publint": "^0.3.16",
    "tsdown": "^0.20.3",
    "wrangler": "^4.78.0"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "assets",
    "dist"
  ],
  "homepage": "https://github.com/schoolforprofessionals/sfp-images#readme",
  "keywords": [
    "cli",
    "image-generation",
    "school-for-professionals",
    "sfp",
    "site-images"
  ],
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "name": "sfp-images",
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schoolforprofessionals/sfp-images.git"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "check-built-package": "bun run ./test/check-built-package.ts",
    "check-types": "bun run generate:worker-font-source && tsc -b --noEmit",
    "ci": "bun run build && bun run check-built-package && bun run lint && bun run check-types && bun test && bun run test:worker",
    "dev": "bun run ./src/cli.ts",
    "generate:worker-font-source": "bun run ./scripts/generate-worker-font-source.ts",
    "lint": "biome check --error-on-warnings",
    "lint:fix": "biome check --error-on-warnings --write",
    "prebuild": "bun run generate:worker-font-source",
    "release": "changeset publish",
    "ruler:apply": "ruler apply --local-only",
    "test": "bun run generate:worker-font-source && bun test",
    "test:watch": "bun test --watch",
    "test:worker": "bun run generate:worker-font-source && RUN_WORKER_TESTS=1 bun run ./test/api-worker.test.ts",
    "version": "changeset version && bun lint:fix"
  },
  "type": "module",
  "types": "./dist/index.d.mts",
  "version": "0.0.0"
}
